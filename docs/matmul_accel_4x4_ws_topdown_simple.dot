// Simple horizontal top-down view of MatmulAccel4x4WS.
// MatmulAccel4x4WS instantiates SystolicArrayWSRoCC with a 4x4 weight-stationary array.
//
// Render with:
//   dot -Tsvg docs/matmul_accel_4x4_ws_topdown_simple.dot -o docs/matmul_accel_4x4_ws_topdown_simple.svg

digraph MatmulAccel4x4WSTopDownSimple {
  graph [
    rankdir=TB
    splines=ortho
    nodesep=0.45
    ranksep=0.7
    pad=0.25
    labelloc=t
    labeljust=l
    fontname="Helvetica"
    fontsize=18
    bgcolor="white"
    label="MatmulAccel4x4WS simple flow\nSystolicArrayWSRoCC 4x4 weight-stationary matmul"
  ];

  node [
    shape=box
    style="rounded,filled"
    fontname="Helvetica"
    fontsize=11
    color="#CBD5E1"
    fillcolor="#F8FAFC"
    margin="0.16,0.10"
  ];

  edge [
    fontname="Helvetica"
    fontsize=10
    color="#64748B"
    arrowsize=0.8
  ];

  root [
    shape=oval
    fillcolor="#E2E8F0"
    label="MatmulAccel4x4WS\nSystolicArrayWSRoCC"
  ];

  config [
    fillcolor="#FEF3C7"
    label="Config\nprecision=16\nnRows=4, nCols=4\nmaxK=256\nopcode custom1"
  ];

  command_decode [
    fillcolor="#FEF3C7"
    label="Command Decode"
  ];

  funct0 [
    fillcolor="#FEF3C7"
    label="funct 0: CONFIG\nrs1 = A base\nrs2 = B base\nset configured"
  ];

  funct1 [
    fillcolor="#DBEAFE"
    label="funct 1: RUN_FULL\nrs1 = C base\nrs2 = K\nload/reuse B, load A,\ncompute and write C"
  ];

  funct3 [
    fillcolor="#DBEAFE"
    label="funct 3: PRELOAD_B\nrs1 = B base\nrs2 = K\nfill and pin bCacheBuf"
  ];

  funct6 [
    fillcolor="#DBEAFE"
    label="funct 6: RUN_PRELOADED\nrs1 = A base\nrs2 = C base\nreuse pinned B"
  ];

  b_cache [
    fillcolor="#DBEAFE"
    label="B Weight Cache\ns_req_fill_b_cache -> s_wait_fill_b_cache\nread packed B stream into bCacheBuf\ncan be pinned and reused"
  ];

  chunk_loop [
    fillcolor="#DBEAFE"
    label="K Chunk Loop\ns_prep_chunk\nprocess K in chunks of nRows=4"
  ];

  a_fill [
    fillcolor="#DBEAFE"
    label="Fill A Chunk\ns_req_fill_a -> s_wait_fill_a\nread packed A words into ping-pong aChunkBufs"
  ];

  prefetch [
    fillcolor="#DBEAFE"
    label="Optional A Prefetch\npf_req_fill_a -> pf_wait_fill_a\nload next A chunk while current chunk computes"
  ];

  compute [
    fillcolor="#DCFCE7"
    label="Weight-Stationary Compute\ns_load_weights -> s_feed_rows -> s_wait_chunk_out\nload B tile into core\nfeed A rows\ncapture partial outputs"
  ];

  accumulate [
    fillcolor="#DCFCE7"
    label="Accumulate Output Tile\ncore outValid adds rows into accumTile\nrepeat until all K chunks complete"
  ];

  quantize [
    fillcolor="#E2E8F0"
    label="Optional BF16 Pack\ns_quantize_out\nconvert accumTile to BF16\npack outputs into xLen words"
  ];

  writeback [
    fillcolor="#E2E8F0"
    label="Write C Tile\ns_req_put -> s_wait_put\nTileLink Put packed output words"
  ];

  resp [
    shape=oval
    fillcolor="#E2E8F0"
    label="Respond\ns_resp -> s_idle"
  ];

  note [
    shape=note
    fillcolor="#FFF7ED"
    color="#FDBA74"
    label="Software can preload B once, then call run_preloaded for many A tiles.\nThis is the tile-level weight-stationary reuse path."
  ];

  root -> config;
  root -> command_decode;
  root -> note [style=dashed, color="#D97706"];

  command_decode -> funct0;
  command_decode -> funct1;
  command_decode -> funct3;
  command_decode -> funct6;

  funct0 -> resp;

  funct1 -> b_cache [xlabel="B not reusable"];
  funct1 -> chunk_loop [xlabel="B reusable\nor K=0"];
  funct3 -> b_cache;
  funct6 -> chunk_loop [xlabel="B pinned valid"];

  b_cache -> chunk_loop [xlabel="run"];
  b_cache -> resp [xlabel="preload only"];

  chunk_loop -> a_fill;
  a_fill -> compute;
  compute -> prefetch [style=dashed, xlabel="if enabled"];
  compute -> accumulate;
  accumulate -> chunk_loop [xlabel="more K"];
  accumulate -> quantize [xlabel="done"];
  quantize -> writeback;
  writeback -> resp;
}
