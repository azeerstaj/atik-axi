// Render with:
//   dot -Tsvg docs/fused_attention_ws_fsm.dot -o docs/fused_attention_ws_fsm.svg

digraph FusedAttentionWSControl {
  graph [
    rankdir=LR
    labelloc=t
    labeljust=l
    newrank=true
    compound=true
    pad=0.35
    nodesep=0.5
    ranksep=0.9
    splines=polyline
    fontname="Helvetica"
    fontsize=20
    label="FusedAttentionWS control visualization\nCommand decode, 25-state main FSM, score postprocessing, softmax passes, and writeback\nSource: src/main/scala/FusedAttentionWS.scala"
    bgcolor="white"
  ];

  node [shape=plain, fontname="Helvetica", margin=0];
  edge [fontname="Helvetica", fontsize=10, color="#475569", arrowsize=0.8];

  legend [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#CBD5E1">
        <TR><TD BGCOLOR="#E2E8F0"><B>Legend</B></TD></TR>
        <TR><TD ALIGN="LEFT">Solid arrows: main <B>state</B> transitions</TD></TR>
        <TR><TD ALIGN="LEFT">Dashed arrows: concurrent side effects or explanatory dataflow notes</TD></TR>
        <TR><TD ALIGN="LEFT">Amber nodes: RoCC command cases decoded from <B>s_idle</B></TD></TR>
        <TR><TD ALIGN="LEFT">Blue nodes: Q fill, shared B/V fill, and QK compute phase</TD></TR>
        <TR><TD ALIGN="LEFT">Teal nodes: softmax phase</TD></TR>
        <TR><TD ALIGN="LEFT">Green nodes: PV phase</TD></TR>
        <TR><TD ALIGN="LEFT">Gray nodes: idle, quantize, writeback, and response</TD></TR>
      </TABLE>
    >
  ];

  buffers_note [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#CBD5E1">
        <TR><TD BGCOLOR="#F8FAFC"><B>Always-On Control / Buffer Facts</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Defaults:</B> <B>core.io.loadWeights</B> = 0, <B>core.io.clearWeights</B> = 0, <B>core.io.inValid</B> = 0, <B>tlOut.a.valid</B> = 0, <B>tlOut.d.ready</B> = 0</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Interface:</B> <B>io.busy := state =/= s_idle</B>, <B>io.interrupt := 0</B>, <B>io.cmd.ready := (state == s_idle)</B>, <B>io.resp.valid := (state == s_resp)</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>aTileBuf role 1:</B> during Q/QK it stores packed Q rows, indexed by <B>k</B>, each entry holding <B>nRows</B> BF16 lanes</TD></TR>
        <TR><TD ALIGN="LEFT"><B>aTileBuf role 2:</B> after softmax it is reused to store probabilities, with <B>aTileBuf(kvIdx)(qRow)</B> = softmax probability</TD></TR>
        <TR><TD ALIGN="LEFT"><B>bTileBuf:</B> stores either K tile columns or V columns, depending on <B>bFillForPV</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>scoreBuf:</B> full post-scaled, causal-masked QK score matrix for all <B>qRows</B> by <B>kvRows</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>accumTile:</B> live MAC accumulation buffer for both QK and PV mesh phases</TD></TR>
        <TR><TD ALIGN="LEFT"><B>weightTile(wr)(wc):</B> from <B>bTileBuf(computeKBaseIdx + wr)(wc)</B> when <B>wr &lt; computeChunkK</B> and <B>wc &lt; activeTileCols</B>, else 0</TD></TR>
        <TR><TD ALIGN="LEFT"><B>currentInVec(lane):</B> from <B>aTileBuf(computeKBaseIdx + lane)(feedRowIdx)</B> when <B>lane &lt; computeChunkK</B> and <B>feedRowIdx &lt; qRows</B>, else 0</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Key source lines:</B> 199-228, 401-410</TD></TR>
      </TABLE>
    >
  ];

  score_post_note [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#FBBF24">
        <TR><TD BGCOLOR="#FEF3C7"><B>QK Score Postprocessing</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Input:</B> raw fixed-point QK partial sums in <B>accumTile</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Scale:</B> convert <B>scaleBf16</B> into fixed-point, multiply each accumulated score, then shift by <B>scoreFracBits</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Convert:</B> fixed-point score to BF16 with <B>SIntFixedToBFloat16</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Causal mask:</B> when <B>causalEn</B> and <B>(qkTileBase + c) &gt; (queryPosBase + r)</B>, replace score with <B>minBf16</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Stored in:</B> <B>scoreBuf(r)(qkTileBase + c)</B> during <B>s_qk_store_scores</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Key source lines:</B> 230-245, 646-671</TD></TR>
      </TABLE>
    >
  ];

  softmax_note [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#67E8F9">
        <TR><TD BGCOLOR="#CFFAFE"><B>Softmax Datapath Summary</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Pass 1:</B> scan one row of <B>scoreBuf</B> in <B>nCols</B>-wide chunks; update running max <B>softMaxPrev</B> and running denominator accumulator <B>softAccum</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Reciprocal:</B> after pass 1, derive <B>softInvSum</B> from <B>softAccumNext</B> with a LUT-based reciprocal approximation</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Pass 2:</B> reload the same scores, compute normalized probabilities <B>softProbBf16</B>, and write them into <B>aTileBuf</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Latched working set:</B> <B>softLatchedScores</B>, <B>softRowIdx</B>, <B>softColIdx</B>, <B>softAccum</B>, <B>softMaxPrev</B>, <B>softInvSum</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Why aTileBuf matters:</B> PV reuse is achieved by turning the normalized attention matrix into the new A-side input buffer</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Key source lines:</B> 248-309, 674-738</TD></TR>
      </TABLE>
    >
  ];

  capture_note [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#FDBA74">
        <TR><TD BGCOLOR="#FFEDD5"><B>Concurrent Output Capture</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Trigger:</B> <B>when(core.io.outValid)</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Guard:</B> only write results when <B>captureRowIdx &lt; qRows</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Action:</B> for each active output column, <B>accumTile(captureRowIdx)(c) += core.io.outVec(c)</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Counter update:</B> <B>captureRowIdx := captureRowIdx + 1</B> on every output-valid pulse</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Applies to:</B> both QK and PV compute phases; explicit wait states simply stall until enough rows have retired</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Key source lines:</B> 516-526</TD></TR>
      </TABLE>
    >
  ];

  command_dispatch [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#FCD34D">
        <TR><TD BGCOLOR="#FEF3C7"><B>RoCC Command Dispatch</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Guard:</B> command decode only runs on <B>io.cmd.fire</B>, and <B>io.cmd.ready</B> is only true in <B>s_idle</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Always writes first:</B> <B>respRd := io.cmd.bits.inst.rd</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Key source lines:</B> 417-513 and software/include/attention.h lines 124-132</TD></TR>
      </TABLE>
    >
  ];

  subgraph cluster_commands {
    label="Command Cases Reached From s_idle";
    color="#FCD34D";
    style="rounded";

    cmd_set_qk_addrs [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 0 : SET_QK_ADDRS</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>qBase := rs1</B>, <B>kTilesBase := rs2</B>, <B>qkAddrsConfigured := 1</B>, <B>respData := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 421-427</TD></TR>
        </TABLE>
      >
    ];

    cmd_set_vout_addrs [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 1 : SET_VOUT_ADDRS</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>vBase := rs1</B>, <B>outBase := rs2</B>, <B>vOutAddrsConfigured := 1</B>, <B>respData := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 427-433</TD></TR>
        </TABLE>
      >
    ];

    cmd_set_dims [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 2 : SET_DIMS</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>rs1 packing:</B> <B>qRows</B> in bits 15:0, <B>kvRows</B> in 31:16, <B>dK</B> in 47:32, <B>valueCols</B> in 63:48</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> unpack those fields into the corresponding registers, set <B>dimsConfigured := 1</B>, <B>respData := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 433-441</TD></TR>
        </TABLE>
      >
    ];

    cmd_set_params [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 3 : SET_PARAMS</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>scaleBf16 := rs1[15:0]</B>, <B>causalEn := rs1[16]</B>, <B>queryPosBase := rs2</B>, <B>respData := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 441-447</TD></TR>
        </TABLE>
      >
    ];

    cmd_run [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 4 : RUN</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>dimsValid:</B> addresses configured, dims configured, all dimensions nonzero, and <B>qRows &lt;= nRows</B>, <B>kvRows &lt;= maxK</B>, <B>dK &lt;= maxK</B>, <B>valueCols &lt;= nCols</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>respData:</B> 1 if config missing, 2 if dims invalid, else 0</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Reset run-local control:</B> zero the Q/B fill indices, tile base, compute counters, feed/capture counters, softmax counters, and <B>outIdx</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Clear buffers:</B> zero all of <B>aTileBuf</B>; zero all of <B>accumTile</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_req_fill_q</B> when valid, else <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfRunCmds</B>++</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 447-491</TD></TR>
        </TABLE>
      >
    ];

    cmd_status [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 5 : STATUS</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>respData = Cat(..., busy, dimsConfigured, addrsConfigured, inResp)</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Meaning:</B> bit 0 = in response state, bit 1 = address config complete, bit 2 = dimension config complete, bit 3 = busy</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 492-500</TD></TR>
        </TABLE>
      >
    ];

    cmd_read_counter [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 6 : READ_COUNTER</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Result:</B> valid counter returns <B>perfCounters(counterIdx)</B>; out of range returns <B>0xBAD0BAD0BAD0BAD0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 501-505</TD></TR>
        </TABLE>
      >
    ];

    cmd_clear_counters [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 7 : CLEAR_COUNTERS</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>clearPerfCounters := 1</B>, <B>respData := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 506-509 and 825-828</TD></TR>
        </TABLE>
      >
    ];

    cmd_unknown [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>otherwise : UNKNOWN</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>respData := 0xDEAD</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 510-512</TD></TR>
        </TABLE>
      >
    ];
  }

  subgraph cluster_main_fsm {
    label="Main FSM (state register)";
    color="#94A3B8";
    style="rounded";

    idle [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#94A3B8">
          <TR><TD BGCOLOR="#E2E8F0"><B>s_idle</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> quiescent state; only place where a new RoCC command is accepted</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Outputs:</B> <B>io.busy := 0</B>, <B>io.cmd.ready := 1</B>, <B>io.resp.valid := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 405-410, 417-513</TD></TR>
        </TABLE>
      >
    ];

    req_fill_q [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_req_fill_q</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> issue the next packed-Q read beat</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.a.valid := 1</B>, <B>tlOut.a.bits := qGetBits</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On a.fire:</B> <B>perfTLReadReqs</B>++, then <B>state := s_wait_fill_q</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Address basis:</B> <B>qBase + qFillIdx * xlenBytes</B>, beat-aligned if needed</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 321-342, 528-535</TD></TR>
        </TABLE>
      >
    ];

    wait_fill_q [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_wait_fill_q</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> consume one packed-Q read response beat into <B>aTileBuf</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.d.ready := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On d.fire:</B> each valid returned word lane expands into <B>nRows</B> BF16 elements stored at <B>aTileBuf(qDestIdx)(r)</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> loop until <B>qFillIdx</B> covers all <B>dK</B>; then clear <B>qFillIdx</B> and go to <B>s_qk_setup_tile</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfWaitQFillCycles</B>++ while active</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 537-559, 842-844</TD></TR>
        </TABLE>
      >
    ];

    qk_setup_tile [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_qk_setup_tile</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> choose the next KV-column tile for QK</TD></TR>
          <TR><TD ALIGN="LEFT"><B>activeTileCols := min(kvRows - qkTileBase, nCols)</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>B fill config:</B> <B>bFillBaseAddr := kTilesBase + ((qkTileBase &gt;&gt; tileShift) * maxK * xlenBytes)</B>, <B>bFillCount := dK</B>, <B>bFillForPV := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Compute reset:</B> <B>bFillIdx := 0</B>, <B>computeKBaseIdx := 0</B>, <B>computeKRemaining := 0</B>, zero all of <B>accumTile</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_req_fill_b</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 561-577</TD></TR>
        </TABLE>
      >
    ];

    req_fill_b [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_req_fill_b</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Shared purpose:</B> issue a packed read beat for either K tiles or V vectors</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.a.valid := 1</B>, <B>tlOut.a.bits := bGetBits</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Selector:</B> <B>bFillForPV = 0</B> means K/QK fill, <B>bFillForPV = 1</B> means V/PV fill</TD></TR>
          <TR><TD ALIGN="LEFT"><B>On a.fire:</B> <B>perfTLReadReqs</B>++, then <B>state := s_wait_fill_b</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 344-365, 579-586</TD></TR>
        </TABLE>
      >
    ];

    wait_fill_b [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_wait_fill_b</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Shared purpose:</B> consume one packed read response beat into <B>bTileBuf</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.d.ready := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On d.fire:</B> each valid returned word lane expands into <B>nCols</B> BF16 elements stored at <B>bTileBuf(bDestIdx)(c)</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>When fill completes:</B> clear <B>bFillIdx</B>, clear <B>computeKBaseIdx</B>, set <B>computeKRemaining := dK</B> for QK or <B>kvRows</B> for PV</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_qk_prep_chunk</B> when <B>!bFillForPV</B>, else <B>s_pv_prep_chunk</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfWaitKFillCycles</B>++ here during QK, <B>perfWaitVFillCycles</B>++ here during PV</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 588-612, 845-847, 860-861</TD></TR>
        </TABLE>
      >
    ];

    qk_prep_chunk [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_qk_prep_chunk</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> decide whether another QK chunk is needed</TD></TR>
          <TR><TD ALIGN="LEFT"><B>If computeKRemaining == 0:</B> QK MACs for this KV tile are finished, so go store postprocessed scores</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Else:</B> <B>computeChunkK := min(computeKRemaining, nRows)</B>, <B>feedRowIdx := 0</B>, <B>captureRowIdx := 0</B>, then load weights</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_qk_store_scores</B> or <B>s_qk_load_weights</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 614-623</TD></TR>
        </TABLE>
      >
    ];

    qk_load_weights [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_qk_load_weights</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> pulse mesh weight loading for one QK chunk</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>core.io.loadWeights := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_qk_feed_rows</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf bucket:</B> counted under <B>perfQKComputeCycles</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 625-628, 848-850</TD></TR>
        </TABLE>
      >
    ];

    qk_feed_rows [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_qk_feed_rows</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> drive Q rows from <B>aTileBuf</B> into the mesh for the current QK chunk</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>core.io.inValid := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>feedRowIdx := feedRowIdx + 1</B> every cycle</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> once <B>feedRowIdx == nRows - 1</B>, transition to <B>s_qk_wait_chunk_out</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf bucket:</B> counted under <B>perfQKComputeCycles</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 630-636, 848-850</TD></TR>
        </TABLE>
      >
    ];

    qk_wait_chunk_out [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_qk_wait_chunk_out</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> wait for all output rows of the current QK chunk to retire</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Exit guard:</B> <B>captureRowIdx == nRows</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Exit writes:</B> <B>computeKRemaining := computeKRemaining - computeChunkK</B>, <B>computeKBaseIdx := computeKBaseIdx + computeChunkK</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_qk_prep_chunk</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf bucket:</B> counted under <B>perfQKComputeCycles</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 638-644, 848-850</TD></TR>
        </TABLE>
      >
    ];

    qk_store_scores [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_qk_store_scores</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> commit the BF16 postprocessed QK outputs for the current KV tile into <B>scoreBuf</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> for valid query rows and active columns, <B>scoreBuf(r)(qkTileBase + c) := scorePostBf16(r)(c)</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>If more KV tiles remain:</B> <B>qkTileBase := qkTileBase + nCols</B> and go load the next K tile</TD></TR>
          <TR><TD ALIGN="LEFT"><B>If last tile finished:</B> zero all of <B>aTileBuf</B>, clear the softmax row/col accumulators, and start softmax row processing</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfScorePostCycles</B>++ while active</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 646-672, 851-853</TD></TR>
        </TABLE>
      >
    ];

    softmax_row_init [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#67E8F9">
          <TR><TD BGCOLOR="#CFFAFE"><B>s_softmax_row_init</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> reset softmax working registers for one query row</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>softColIdx := 0</B>, <B>softAccum := 0</B>, <B>softMaxPrev := minBf16</B>, <B>softInvSum := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_softmax_p1_load</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 674-680</TD></TR>
        </TABLE>
      >
    ];

    softmax_p1_load [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#67E8F9">
          <TR><TD BGCOLOR="#CFFAFE"><B>s_softmax_p1_load</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> fetch one <B>nCols</B>-wide score slice of the current query row into <B>softLatchedScores</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> <B>scoreBuf(softRowIdx)(softColIdx + lane)</B>; out-of-range lanes are padded with <B>minBf16</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_softmax_p1_compute</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> counted under <B>perfSoftmaxPass1Cycles</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 682-690, 854-856</TD></TR>
        </TABLE>
      >
    ];

    softmax_p1_compute [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#67E8F9">
          <TR><TD BGCOLOR="#CFFAFE"><B>s_softmax_p1_compute</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> update the running max and running denominator for the current query row</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>softAccum := softAccumNext</B>, <B>softMaxPrev := softGlobalMax.io.out</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>If row scan finished:</B> <B>softColIdx := 0</B>, <B>softInvSum := softInvSumCandidate</B>, then start pass 2</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Else:</B> <B>softColIdx := softColIdx + nCols</B> and loop back to load the next slice</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> counted under <B>perfSoftmaxPass1Cycles</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 692-704, 854-856</TD></TR>
        </TABLE>
      >
    ];

    softmax_p2_load [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#67E8F9">
          <TR><TD BGCOLOR="#CFFAFE"><B>s_softmax_p2_load</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> reload the same score slice for normalization</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> repopulate <B>softLatchedScores</B> from <B>scoreBuf</B> with the same out-of-range padding as pass 1</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_softmax_p2_compute</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> counted under <B>perfSoftmaxPass2Cycles</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 706-714, 857-859</TD></TR>
        </TABLE>
      >
    ];

    softmax_p2_compute [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#67E8F9">
          <TR><TD BGCOLOR="#CFFAFE"><B>s_softmax_p2_compute</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> generate normalized BF16 probabilities and write them into <B>aTileBuf</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> for valid lanes, <B>aTileBuf(kvIdx)(softRowIdx) := softProbBf16(lane)</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>If row finished and last row:</B> proceed to PV setup</TD></TR>
          <TR><TD ALIGN="LEFT"><B>If row finished and more rows remain:</B> <B>softRowIdx := softRowIdx + 1</B> and restart at <B>s_softmax_row_init</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Else:</B> <B>softColIdx := softColIdx + nCols</B> and reload the next slice</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> counted under <B>perfSoftmaxPass2Cycles</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 716-738, 857-859</TD></TR>
        </TABLE>
      >
    ];

    pv_setup [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#86EFAC">
          <TR><TD BGCOLOR="#DCFCE7"><B>s_pv_setup</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> repoint the shared B-fill path at V and prepare for probability-times-value computation</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>activeTileCols := valueCols</B>, <B>bFillBaseAddr := vBase</B>, <B>bFillCount := kvRows</B>, <B>bFillIdx := 0</B>, <B>bFillForPV := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Reset compute:</B> <B>computeKBaseIdx := 0</B>, <B>computeKRemaining := 0</B>, zero all of <B>accumTile</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> reuse <B>s_req_fill_b</B> / <B>s_wait_fill_b</B> to fetch V</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 740-754</TD></TR>
        </TABLE>
      >
    ];

    pv_prep_chunk [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#86EFAC">
          <TR><TD BGCOLOR="#DCFCE7"><B>s_pv_prep_chunk</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> decide whether another PV chunk is needed</TD></TR>
          <TR><TD ALIGN="LEFT"><B>If computeKRemaining == 0:</B> PV MACs are done, so start output quantization/packing</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Else:</B> <B>computeChunkK := min(computeKRemaining, nRows)</B>, <B>feedRowIdx := 0</B>, <B>captureRowIdx := 0</B>, then load V weights</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_quantize_out</B> or <B>s_pv_load_weights</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 756-766</TD></TR>
        </TABLE>
      >
    ];

    pv_load_weights [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#86EFAC">
          <TR><TD BGCOLOR="#DCFCE7"><B>s_pv_load_weights</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> pulse mesh weight loading for one PV chunk</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>core.io.loadWeights := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_pv_feed_rows</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf bucket:</B> counted under <B>perfPVComputeCycles</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 768-771, 863-865</TD></TR>
        </TABLE>
      >
    ];

    pv_feed_rows [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#86EFAC">
          <TR><TD BGCOLOR="#DCFCE7"><B>s_pv_feed_rows</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> drive probability rows from <B>aTileBuf</B> into the mesh for the current PV chunk</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>core.io.inValid := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>feedRowIdx := feedRowIdx + 1</B> every cycle</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> once <B>feedRowIdx == nRows - 1</B>, transition to <B>s_pv_wait_chunk_out</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf bucket:</B> counted under <B>perfPVComputeCycles</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 773-779, 863-865</TD></TR>
        </TABLE>
      >
    ];

    pv_wait_chunk_out [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#86EFAC">
          <TR><TD BGCOLOR="#DCFCE7"><B>s_pv_wait_chunk_out</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> wait for all output rows of the current PV chunk to retire</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Exit guard:</B> <B>captureRowIdx == nRows</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Exit writes:</B> <B>computeKRemaining := computeKRemaining - computeChunkK</B>, <B>computeKBaseIdx := computeKBaseIdx + computeChunkK</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_pv_prep_chunk</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf bucket:</B> counted under <B>perfPVComputeCycles</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 781-787, 863-865</TD></TR>
        </TABLE>
      >
    ];

    quantize_out [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#94A3B8">
          <TR><TD BGCOLOR="#E2E8F0"><B>s_quantize_out</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> register the BF16-packed output words before TileLink writeback</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>packedStoreWordsReg(w) := packedStoreWordsWire(w)</B> for every output word</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_req_put</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 789-794</TD></TR>
        </TABLE>
      >
    ];

    req_put [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#94A3B8">
          <TR><TD BGCOLOR="#E2E8F0"><B>s_req_put</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> issue one output write beat</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.a.valid := 1</B>, <B>tlOut.a.bits := putBits</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Payload:</B> packed BF16 output words from <B>packedStoreWordsReg</B>, masked by valid write lanes in the current beat</TD></TR>
          <TR><TD ALIGN="LEFT"><B>On a.fire:</B> <B>perfTLWriteReqs</B>++, then <B>state := s_wait_put</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 367-399, 796-803, 839-841</TD></TR>
        </TABLE>
      >
    ];

    wait_put [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#94A3B8">
          <TR><TD BGCOLOR="#E2E8F0"><B>s_wait_put</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> wait for the TileLink write acknowledgement for the current output beat</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.d.ready := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On d.fire:</B> check write ack/source, compute <B>nextOutIdx := outIdx + writeWordsThisBeat</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> loop to <B>s_req_put</B> if more words remain, else set <B>respData := 0</B> and go to <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfWaitPutCycles</B>++ while active</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 805-819, 866-867</TD></TR>
        </TABLE>
      >
    ];

    resp [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#94A3B8">
          <TR><TD BGCOLOR="#E2E8F0"><B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> return the prepared result on the RoCC response channel</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Outputs:</B> <B>io.resp.valid := 1</B>, <B>io.resp.bits.rd := respRd</B>, <B>io.resp.bits.data := respData</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On resp.fire:</B> <B>state := s_idle</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 408-410, 821-823</TD></TR>
        </TABLE>
      >
    ];
  }

  { rank=same; legend; buffers_note; }

  idle -> command_dispatch [style=dashed, color="#D97706", label="io.cmd.fire"];
  command_dispatch -> cmd_set_qk_addrs [style=dashed, color="#D97706", label="funct == 0"];
  command_dispatch -> cmd_set_vout_addrs [style=dashed, color="#D97706", label="funct == 1"];
  command_dispatch -> cmd_set_dims [style=dashed, color="#D97706", label="funct == 2"];
  command_dispatch -> cmd_set_params [style=dashed, color="#D97706", label="funct == 3"];
  command_dispatch -> cmd_run [style=dashed, color="#D97706", label="funct == 4"];
  command_dispatch -> cmd_status [style=dashed, color="#D97706", label="funct == 5"];
  command_dispatch -> cmd_read_counter [style=dashed, color="#D97706", label="funct == 6"];
  command_dispatch -> cmd_clear_counters [style=dashed, color="#D97706", label="funct == 7"];
  command_dispatch -> cmd_unknown [style=dashed, color="#D97706", label="otherwise"];

  cmd_set_qk_addrs -> resp [label="always"];
  cmd_set_vout_addrs -> resp [label="always"];
  cmd_set_dims -> resp [label="always"];
  cmd_set_params -> resp [label="always"];
  cmd_run -> req_fill_q [label="dimsValid"];
  cmd_run -> resp [label="!dimsValid"];
  cmd_status -> resp [label="always"];
  cmd_read_counter -> resp [label="always"];
  cmd_clear_counters -> resp [label="always"];
  cmd_unknown -> resp [label="always"];

  req_fill_q -> req_fill_q [color="#94A3B8", fontcolor="#64748B", label="wait for tlOut.a.fire"];
  req_fill_q -> wait_fill_q [label="tlOut.a.fire"];

  wait_fill_q -> wait_fill_q [color="#94A3B8", fontcolor="#64748B", label="wait for tlOut.d.fire"];
  wait_fill_q -> req_fill_q [label="d.fire and nextIdx < dK"];
  wait_fill_q -> qk_setup_tile [label="d.fire and nextIdx >= dK"];

  qk_setup_tile -> req_fill_b [label="start K-tile fill"];

  req_fill_b -> req_fill_b [color="#94A3B8", fontcolor="#64748B", label="wait for tlOut.a.fire"];
  req_fill_b -> wait_fill_b [label="tlOut.a.fire"];

  wait_fill_b -> wait_fill_b [color="#94A3B8", fontcolor="#64748B", label="wait for tlOut.d.fire"];
  wait_fill_b -> req_fill_b [label="d.fire and nextIdx < bFillCount"];
  wait_fill_b -> qk_prep_chunk [label="d.fire and nextIdx >= bFillCount and !bFillForPV"];
  wait_fill_b -> pv_prep_chunk [label="d.fire and nextIdx >= bFillCount and bFillForPV"];

  qk_prep_chunk -> qk_store_scores [label="computeKRemaining == 0"];
  qk_prep_chunk -> qk_load_weights [label="computeKRemaining != 0"];
  qk_load_weights -> qk_feed_rows [label="next cycle"];
  qk_feed_rows -> qk_feed_rows [label="feedRowIdx != nRows - 1"];
  qk_feed_rows -> qk_wait_chunk_out [label="feedRowIdx == nRows - 1"];
  qk_wait_chunk_out -> qk_wait_chunk_out [color="#94A3B8", fontcolor="#64748B", label="wait for captureRowIdx == nRows"];
  qk_wait_chunk_out -> qk_prep_chunk [label="captureRowIdx == nRows"];

  qk_store_scores -> qk_setup_tile [label="qkTileBase + nCols < kvRows"];
  qk_store_scores -> softmax_row_init [label="qkTileBase + nCols >= kvRows"];

  softmax_row_init -> softmax_p1_load [label="start pass 1"];
  softmax_p1_load -> softmax_p1_compute [label="latched"];
  softmax_p1_compute -> softmax_p1_load [label="nextCol < kvRows"];
  softmax_p1_compute -> softmax_p2_load [label="nextCol >= kvRows"];
  softmax_p2_load -> softmax_p2_compute [label="latched"];
  softmax_p2_compute -> softmax_p2_load [label="nextCol < kvRows"];
  softmax_p2_compute -> softmax_row_init [label="row done and softRowIdx + 1 < qRows"];
  softmax_p2_compute -> pv_setup [label="row done and softRowIdx + 1 >= qRows"];

  pv_setup -> req_fill_b [label="start V fill"];
  pv_prep_chunk -> quantize_out [label="computeKRemaining == 0"];
  pv_prep_chunk -> pv_load_weights [label="computeKRemaining != 0"];
  pv_load_weights -> pv_feed_rows [label="next cycle"];
  pv_feed_rows -> pv_feed_rows [label="feedRowIdx != nRows - 1"];
  pv_feed_rows -> pv_wait_chunk_out [label="feedRowIdx == nRows - 1"];
  pv_wait_chunk_out -> pv_wait_chunk_out [color="#94A3B8", fontcolor="#64748B", label="wait for captureRowIdx == nRows"];
  pv_wait_chunk_out -> pv_prep_chunk [label="captureRowIdx == nRows"];

  quantize_out -> req_put [label="packedStoreWordsReg loaded"];
  req_put -> req_put [color="#94A3B8", fontcolor="#64748B", label="wait for tlOut.a.fire"];
  req_put -> wait_put [label="tlOut.a.fire"];
  wait_put -> wait_put [color="#94A3B8", fontcolor="#64748B", label="wait for tlOut.d.fire"];
  wait_put -> req_put [label="d.fire and nextOutIdx < outputWordCount"];
  wait_put -> resp [label="d.fire and nextOutIdx >= outputWordCount"];
  resp -> idle [label="io.resp.fire"];

  qk_load_weights -> capture_note [style=dashed, color="#EA580C", label="QK chunk begins"];
  qk_feed_rows -> capture_note [style=dashed, color="#EA580C", label="future outValid pulses"];
  qk_wait_chunk_out -> capture_note [style=dashed, color="#EA580C", label="QK drain happens here"];
  pv_load_weights -> capture_note [style=dashed, color="#EA580C", label="PV chunk begins"];
  pv_feed_rows -> capture_note [style=dashed, color="#EA580C", label="future outValid pulses"];
  pv_wait_chunk_out -> capture_note [style=dashed, color="#EA580C", label="PV drain happens here"];

  qk_store_scores -> score_post_note [style=dashed, color="#D97706", label="scoreBuf writes"];
  softmax_p1_compute -> softmax_note [style=dashed, color="#0891B2", label="running max / sum"];
  softmax_p2_compute -> softmax_note [style=dashed, color="#0891B2", label="normalize into aTileBuf"];
}
