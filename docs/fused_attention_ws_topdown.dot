// Phase-oriented top-down control view for FusedAttentionWS.
// This is intentionally hierarchical rather than cycle-accurate left-to-right FSM art.
//
// Render with:
//   dot -Tsvg docs/fused_attention_ws_topdown.dot -o docs/fused_attention_ws_topdown.svg

digraph FusedAttentionWSTopDown {
  graph [
    rankdir=TB
    splines=ortho
    nodesep=0.40
    ranksep=0.70
    pad=0.30
    labelloc=t
    labeljust=l
    fontname="Helvetica"
    fontsize=20
    bgcolor="white"
    label="FusedAttentionWS top-down control view\nPhase tree with real state groups, loop guards, and key register updates"
  ];

  node [
    shape=box
    style="rounded,filled"
    fontname="Helvetica"
    fontsize=10
    margin="0.18,0.10"
    color="#CBD5E1"
    fillcolor="#F8FAFC"
  ];

  edge [
    color="#64748B"
    arrowsize=0.8
    penwidth=1.0
  ];

  root [
    shape=oval
    fillcolor="#E2E8F0"
    color="#94A3B8"
    fontsize=12
    label="FusedAttentionWS\nTop-Down Control"
  ];

  legend [
    shape=note
    fillcolor="#FFF7ED"
    color="#FDBA74"
    label="Reading guide\n- This graph groups states by purpose.\n- Each box names the real state(s) used in RTL.\n- Loop boxes explain repetition; they do not draw literal back-edges.\n- Source RTL: src/main/scala/FusedAttentionWS.scala"
  ];

  setup_branch [
    fillcolor="#FEF3C7"
    color="#FCD34D"
    fontsize=11
    label="Setup / Service Commands\nAccepted only when state == s_idle"
  ];

  run_branch [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    fontsize=11
    label="Run Path\nfunct = 4"
  ];

  root -> setup_branch;
  root -> run_branch;
  root -> legend [style=dashed, color="#D97706"];

  setup_cfg [
    fillcolor="#FEF3C7"
    color="#FCD34D"
    label="Configuration Commands\nEach one writes registers and then goes to s_resp"
  ];

  setup_service [
    fillcolor="#FEF3C7"
    color="#FCD34D"
    label="Service Commands\nStatus / counters / clear"
  ];

  setup_branch -> setup_cfg;
  setup_branch -> setup_service;

  cmd_qk_addrs [
    fillcolor="#FEF3C7"
    color="#FCD34D"
    label="funct = 0  SET_QK_ADDRS\nqBase := rs1\nkTilesBase := rs2\nqkAddrsConfigured := 1\nrespData := 0\nnext: s_resp"
  ];

  cmd_vout_addrs [
    fillcolor="#FEF3C7"
    color="#FCD34D"
    label="funct = 1  SET_VOUT_ADDRS\nvBase := rs1\noutBase := rs2\nvOutAddrsConfigured := 1\nrespData := 0\nnext: s_resp"
  ];

  cmd_dims [
    fillcolor="#FEF3C7"
    color="#FCD34D"
    label="funct = 2  SET_DIMS\nqRows := rs1[15:0]\nkvRows := rs1[31:16]\ndK := rs1[47:32]\nvalueCols := rs1[63:48]\ndimsConfigured := 1\nnext: s_resp"
  ];

  cmd_params [
    fillcolor="#FEF3C7"
    color="#FCD34D"
    label="funct = 3  SET_PARAMS\nscaleBf16 := rs1[15:0]\ncausalEn := rs1[16]\nqueryPosBase := rs2\nrespData := 0\nnext: s_resp"
  ];

  setup_cfg -> cmd_qk_addrs;
  setup_cfg -> cmd_vout_addrs;
  setup_cfg -> cmd_dims;
  setup_cfg -> cmd_params;

  cmd_status [
    fillcolor="#FEF3C7"
    color="#FCD34D"
    label="funct = 5  STATUS\nrespData := Cat(...,\n  busy = state =/= s_idle,\n  dimsConfigured,\n  addrsConfigured,\n  inResp = state === s_resp)\nnext: s_resp"
  ];

  cmd_read_counter [
    fillcolor="#FEF3C7"
    color="#FCD34D"
    label="funct = 6  READ_COUNTER\nreturns perfCounters(counterIdx)\nor 0xBAD0BAD0BAD0BAD0\nnext: s_resp"
  ];

  cmd_clear_counter [
    fillcolor="#FEF3C7"
    color="#FCD34D"
    label="funct = 7  CLEAR_COUNTERS\nclearPerfCounters := 1\nrespData := 0\nnext: s_resp"
  ];

  cmd_unknown [
    fillcolor="#FEF3C7"
    color="#FCD34D"
    label="otherwise\nrespData := 0xDEAD\nnext: s_resp"
  ];

  setup_service -> cmd_status;
  setup_service -> cmd_read_counter;
  setup_service -> cmd_clear_counter;
  setup_service -> cmd_unknown;

  run_validate [
    shape=diamond
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Run validation\naddrsConfigured?\ndimsConfigured?\nall dims nonzero?\nqRows <= nRows?\nkvRows <= maxK?\ndK <= maxK?\nvalueCols <= nCols?"
  ];

  run_error [
    fillcolor="#E2E8F0"
    color="#94A3B8"
    label="Run rejected\nrespData := 1 if setup missing\nrespData := 2 if dims invalid\nnext: s_resp"
  ];

  run_init [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Run init\nincRunCmd := 1\nqFillIdx := 0, bFillIdx := 0, qkTileBase := 0\ncomputeKBaseIdx := 0, computeKRemaining := 0, computeChunkK := 0\nfeedRowIdx := 0, captureRowIdx := 0, activeTileCols := 0\nsoftRowIdx := 0, softColIdx := 0, softAccum := 0\nsoftMaxPrev := minBf16, softInvSum := 0, outIdx := 0\nclear aTileBuf\nclear accumTile\nnext: s_req_fill_q"
  ];

  run_branch -> run_validate;
  run_validate -> run_error [xlabel="invalid"];
  run_validate -> run_init [xlabel="valid"];

  q_fill_phase [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    fontsize=11
    label="Phase 1: Fill Q Buffer"
  ];

  run_init -> q_fill_phase;

  q_fill_issue [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Issue Q read beat\nstate: s_req_fill_q\ntlOut.a.valid := 1\ntlOut.a.bits := qGetBits\non a.fire: perfTLReadReqs++\nnext: s_wait_fill_q"
  ];

  q_fill_wait [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Consume Q read beat\nstate: s_wait_fill_q\ntlOut.d.ready := 1\nexpand each returned xLen word into nRows BF16 lanes\nstore into aTileBuf(qDestIdx)(row)"
  ];

  q_fill_loop [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Loop condition\nnextIdx := qFillIdx + qWordsThisBeat\nif nextIdx < dK:\n  qFillIdx := nextIdx and repeat Q read\nelse:\n  qFillIdx := 0 and proceed to QK tile setup"
  ];

  q_fill_phase -> q_fill_issue;
  q_fill_phase -> q_fill_wait;
  q_fill_phase -> q_fill_loop;

  qk_phase [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    fontsize=11
    label="Phase 2: QK Matmul + Score Buffer"
  ];

  q_fill_loop -> qk_phase;

  qk_tile_loop [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Outer tile loop over KV columns\nstarts with qkTileBase = 0\nrepeat while qkTileBase < kvRows"
  ];

  qk_setup_tile [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Setup one K tile\nstate: s_qk_setup_tile\nactiveTileCols := min(kvRows - qkTileBase, nCols)\nbFillBaseAddr := kTilesBase + ((qkTileBase >> tileShift) * maxK * xlenBytes)\nbFillCount := dK\nbFillIdx := 0\nbFillForPV := 0\ncomputeKBaseIdx := 0\ncomputeKRemaining := 0\nclear accumTile\nnext: s_req_fill_b"
  ];

  qk_fill_k [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Fill K tile into bTileBuf\nstates: s_req_fill_b -> s_wait_fill_b\nreads dK packed words from bFillBaseAddr\nstores BF16 lanes into bTileBuf(bDestIdx)(col)\non fill complete:\n  bFillIdx := 0\n  computeKBaseIdx := 0\n  computeKRemaining := dK\n  next: s_qk_prep_chunk"
  ];

  qk_chunk_loop [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Inner chunk loop over dK\nrepeat while computeKRemaining != 0\nchunk size = min(computeKRemaining, nRows)"
  ];

  qk_chunk_prep [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Prepare QK chunk\nstate: s_qk_prep_chunk\nif computeKRemaining == 0:\n  next: s_qk_store_scores\nelse:\n  computeChunkK := min(computeKRemaining, nRows)\n  feedRowIdx := 0\n  captureRowIdx := 0\n  next: s_qk_load_weights"
  ];

  qk_chunk_body [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="QK chunk body\ns_qk_load_weights: core.io.loadWeights := 1\ns_qk_feed_rows: core.io.inValid := 1, feedRowIdx++\ns_qk_wait_chunk_out: wait until captureRowIdx == nRows\nthen:\n  computeKRemaining -= computeChunkK\n  computeKBaseIdx += computeChunkK"
  ];

  qk_score_post [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Scale + mask + store scores\nstate: s_qk_store_scores\nfor each valid row/col:\n  scale accumTile by scaleBf16\n  convert to BF16\n  apply causal mask if enabled\n  scoreBuf(row)(qkTileBase + col) := scorePostBf16(row)(col)"
  ];

  qk_tile_exit [
    fillcolor="#DBEAFE"
    color="#93C5FD"
    label="Tile exit\nif qkTileBase + nCols < kvRows:\n  qkTileBase += nCols and repeat K tile loop\nelse:\n  clear aTileBuf\n  softRowIdx := 0\n  softColIdx := 0\n  softAccum := 0\n  softMaxPrev := minBf16\n  proceed to softmax"
  ];

  qk_phase -> qk_tile_loop;
  qk_phase -> qk_setup_tile;
  qk_phase -> qk_fill_k;
  qk_phase -> qk_chunk_loop;
  qk_phase -> qk_chunk_prep;
  qk_phase -> qk_chunk_body;
  qk_phase -> qk_score_post;
  qk_phase -> qk_tile_exit;

  softmax_phase [
    fillcolor="#CFFAFE"
    color="#67E8F9"
    fontsize=11
    label="Phase 3: Softmax Over scoreBuf"
  ];

  qk_tile_exit -> softmax_phase;

  softmax_row_loop [
    fillcolor="#CFFAFE"
    color="#67E8F9"
    label="Outer row loop\nrepeat for softRowIdx in [0, qRows)"
  ];

  softmax_row_init [
    fillcolor="#CFFAFE"
    color="#67E8F9"
    label="Init one softmax row\nstate: s_softmax_row_init\nsoftColIdx := 0\nsoftAccum := 0\nsoftMaxPrev := minBf16\nsoftInvSum := 0\nnext: s_softmax_p1_load"
  ];

  softmax_p1_loop [
    fillcolor="#CFFAFE"
    color="#67E8F9"
    label="Pass 1 loop over one score row\nstates: s_softmax_p1_load -> s_softmax_p1_compute\nload nCols scores into softLatchedScores\nupdate running max and denominator accumulator"
  ];

  softmax_p1_exit [
    fillcolor="#CFFAFE"
    color="#67E8F9"
    label="Pass 1 exit\nwhen nextCol >= kvRows:\n  softColIdx := 0\n  softInvSum := softInvSumCandidate\n  proceed to pass 2\notherwise:\n  softColIdx += nCols and repeat pass 1"
  ];

  softmax_recip [
    fillcolor="#CFFAFE"
    color="#67E8F9"
    label="Reciprocal path details\nsoftAccumNext -> leading-bit detect -> LUT index\nsoftInvSumCandidate approximates 1 / denominator\nstored in softInvSum before pass 2"
  ];

  softmax_p2_loop [
    fillcolor="#CFFAFE"
    color="#67E8F9"
    label="Pass 2 loop over one score row\nstates: s_softmax_p2_load -> s_softmax_p2_compute\nreload scores\ncompute normalized BF16 probabilities softProbBf16"
  ];

  softmax_p2_store [
    fillcolor="#CFFAFE"
    color="#67E8F9"
    label="Write probabilities into aTileBuf\nstate: s_softmax_p2_compute\nfor each valid lane:\n  aTileBuf(kvIdx)(softRowIdx) := softProbBf16(lane)\nThis repurposes aTileBuf from Q storage into attention probabilities"
  ];

  softmax_row_exit [
    fillcolor="#CFFAFE"
    color="#67E8F9"
    label="Row exit\nif nextCol < kvRows:\n  softColIdx += nCols and repeat pass 2\nelse if softRowIdx + 1 < qRows:\n  softRowIdx += 1 and restart row init\nelse:\n  proceed to PV setup"
  ];

  softmax_phase -> softmax_row_loop;
  softmax_phase -> softmax_row_init;
  softmax_phase -> softmax_p1_loop;
  softmax_phase -> softmax_p1_exit;
  softmax_phase -> softmax_recip;
  softmax_phase -> softmax_p2_loop;
  softmax_phase -> softmax_p2_store;
  softmax_phase -> softmax_row_exit;

  pv_phase [
    fillcolor="#DCFCE7"
    color="#86EFAC"
    fontsize=11
    label="Phase 4: PV Matmul"
  ];

  softmax_row_exit -> pv_phase;

  pv_setup [
    fillcolor="#DCFCE7"
    color="#86EFAC"
    label="Setup PV phase\nstate: s_pv_setup\nactiveTileCols := valueCols\nbFillBaseAddr := vBase\nbFillCount := kvRows\nbFillIdx := 0\nbFillForPV := 1\ncomputeKBaseIdx := 0\ncomputeKRemaining := 0\nclear accumTile\nnext: s_req_fill_b"
  ];

  pv_fill_v [
    fillcolor="#DCFCE7"
    color="#86EFAC"
    label="Fill V into bTileBuf\nstates: s_req_fill_b -> s_wait_fill_b\nreads kvRows packed words from vBase\nstores BF16 lanes into bTileBuf(bDestIdx)(col)\non fill complete:\n  bFillIdx := 0\n  computeKBaseIdx := 0\n  computeKRemaining := kvRows\n  next: s_pv_prep_chunk"
  ];

  pv_chunk_loop [
    fillcolor="#DCFCE7"
    color="#86EFAC"
    label="PV chunk loop over kvRows\nrepeat while computeKRemaining != 0\nchunk size = min(computeKRemaining, nRows)"
  ];

  pv_chunk_prep [
    fillcolor="#DCFCE7"
    color="#86EFAC"
    label="Prepare PV chunk\nstate: s_pv_prep_chunk\nif computeKRemaining == 0:\n  outIdx := 0\n  next: s_quantize_out\nelse:\n  computeChunkK := min(computeKRemaining, nRows)\n  feedRowIdx := 0\n  captureRowIdx := 0\n  next: s_pv_load_weights"
  ];

  pv_chunk_body [
    fillcolor="#DCFCE7"
    color="#86EFAC"
    label="PV chunk body\ns_pv_load_weights: core.io.loadWeights := 1\ns_pv_feed_rows: core.io.inValid := 1, feedRowIdx++\ns_pv_wait_chunk_out: wait until captureRowIdx == nRows\nthen:\n  computeKRemaining -= computeChunkK\n  computeKBaseIdx += computeChunkK"
  ];

  pv_phase -> pv_setup;
  pv_phase -> pv_fill_v;
  pv_phase -> pv_chunk_loop;
  pv_phase -> pv_chunk_prep;
  pv_phase -> pv_chunk_body;

  writeback_phase [
    fillcolor="#E2E8F0"
    color="#94A3B8"
    fontsize=11
    label="Phase 5: Quantize + Writeback + Response"
  ];

  pv_chunk_prep -> writeback_phase;

  quantize_out [
    fillcolor="#E2E8F0"
    color="#94A3B8"
    label="Quantize / pack output\nstate: s_quantize_out\npackedBFloatOut converts accumTile fixed-point values to BF16\npackedStoreWordsWire groups BF16 lanes into xLen words\npackedStoreWordsReg := packedStoreWordsWire\nnext: s_req_put"
  ];

  put_loop [
    fillcolor="#E2E8F0"
    color="#94A3B8"
    label="Writeback loop\ns_req_put: tlOut.a.valid := 1, tlOut.a.bits := putBits\ns_wait_put: tlOut.d.ready := 1\non a.fire: perfTLWriteReqs++\non d.fire:\n  nextOutIdx := outIdx + writeWordsThisBeat\n  if more words remain, outIdx := nextOutIdx and repeat\n  else respData := 0 and go to s_resp"
  ];

  resp_ok [
    fillcolor="#E2E8F0"
    color="#94A3B8"
    label="Response / idle\nstate: s_resp\nio.resp.valid := 1\non io.resp.fire: state := s_idle"
  ];

  writeback_phase -> quantize_out;
  writeback_phase -> put_loop;
  writeback_phase -> resp_ok;

  capture_note [
    shape=note
    fillcolor="#FFEDD5"
    color="#FDBA74"
    label="Concurrent mesh output capture\nwhen core.io.outValid:\n  if captureRowIdx < qRows:\n    accumTile(captureRowIdx)(c) += core.io.outVec(c)\n  captureRowIdx += 1\nThis same mechanism is used in both QK and PV compute phases."
  ];

  buffer_note [
    shape=note
    fillcolor="#FFF7ED"
    color="#FDBA74"
    label="Key buffer-role changes\n- aTileBuf starts as packed Q input.\n- scoreBuf holds the full post-scaled and masked QK score matrix.\n- aTileBuf is later overwritten with softmax probabilities.\n- bTileBuf is first K tiles, then V vectors.\n- accumTile is reused for both QK and PV MAC accumulation."
  ];

  perf_note [
    shape=note
    fillcolor="#FFF7ED"
    color="#FDBA74"
    label="Perf counter grouping\nwait_fill_q -> perfWaitQFillCycles\nwait_fill_b with K -> perfWaitKFillCycles\nQK load/feed/wait -> perfQKComputeCycles\nqk_store_scores -> perfScorePostCycles\nsoftmax pass 1/2 -> dedicated softmax counters\nwait_fill_b with V -> perfWaitVFillCycles\nPV load/feed/wait -> perfPVComputeCycles\nwait_put -> perfWaitPutCycles"
  ];

  qk_chunk_body -> capture_note [style=dashed, color="#EA580C"];
  pv_chunk_body -> capture_note [style=dashed, color="#EA580C"];
  softmax_p2_store -> buffer_note [style=dashed, color="#D97706"];
  root -> perf_note [style=dashed, color="#D97706"];
}
