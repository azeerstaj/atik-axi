// Simple top-down view of SoftmaxAccel.
// Middle-ground version: less detailed than softmax_accel_topdown_minimal.dot,
// but more informative than softmax_accel_topdown_tiny.dot.
//
// Render with:
//   dot -Tsvg docs/softmax_accel_topdown_simple.dot -o docs/softmax_accel_topdown_simple.svg

digraph SoftmaxAccelTopDownSimple {
  graph [
    rankdir=TB
    splines=ortho
    nodesep=0.45
    ranksep=0.7
    pad=0.25
    labelloc=t
    labeljust=l
    fontname="Helvetica"
    fontsize=18
    bgcolor="white"
    label="SoftmaxAccel simple flow\nOnlineSoftmax BF16 two-pass execution"
  ];

  node [
    shape=box
    style="rounded,filled"
    fontname="Helvetica"
    fontsize=11
    color="#CBD5E1"
    fillcolor="#F8FAFC"
    margin="0.16,0.10"
  ];

  edge [
    fontname="Helvetica"
    fontsize=10
    color="#64748B"
    arrowsize=0.8
  ];

  root [
    shape=oval
    fillcolor="#E2E8F0"
    label="SoftmaxAccel\nOnlineSoftmax"
  ];

  command_decode [
    fillcolor="#FEF3C7"
    label="Command Decode"
  ];

  funct0 [
    fillcolor="#DBEAFE"
    label="funct 0: ACCUMULATE\nrs1 = input base\nrs2 = array length\ncompute max + denominator"
  ];

  funct1 [
    fillcolor="#CFFAFE"
    label="funct 1: NORMALIZE_BF16\nrs1 = output base\nreread input and write BF16 probabilities"
  ];

  pass1 [
    fillcolor="#DBEAFE"
    label="Pass 1: Accumulate Denominator\ninput base + length"
  ];

  pass1_read [
    fillcolor="#DBEAFE"
    label="Read Input Beats\ns_acq -> s_gnt\nload BF16 lanes from memory"
  ];

  pass1_math [
    fillcolor="#DBEAFE"
    label="Online Softmax Update\ns_findmax -> s_exp -> s_reduce\nupdate running max and exp sum"
  ];

  saved [
    fillcolor="#FEF3C7"
    label="Saved Between Commands\ninBase, arraySize\nmaxPrev = global max\naccum = denominator"
  ];

  pass2 [
    fillcolor="#CFFAFE"
    label="Pass 2: Normalize + Write\noutput base"
  ];

  reciprocal [
    fillcolor="#CFFAFE"
    label="Compute invSum\nLUT reciprocal of accum"
  ];

  pass2_read [
    fillcolor="#CFFAFE"
    label="Reread Input Beats\ns_acq -> s_gnt\nsame input stream as pass 1"
  ];

  pass2_math [
    fillcolor="#CFFAFE"
    label="Normalize Lanes\ns_exp\nexp(x - maxPrev) * invSum\nconvert to BF16"
  ];

  writeback [
    fillcolor="#DCFCE7"
    label="Write Output Beats\ns_put -> s_put_ack\nTileLink Put with tail mask"
  ];

  resp [
    shape=oval
    fillcolor="#E2E8F0"
    label="Respond\ns_resp -> s_idle"
  ];

  root -> command_decode;

  command_decode -> funct0;
  command_decode -> funct1;

  funct0 -> pass1;
  pass1 -> pass1_read;
  pass1_read -> pass1_math;
  pass1_math -> pass1_read [xlabel="more input"];
  pass1_math -> saved [xlabel="done"];
  saved -> resp;

  funct1 -> pass2;
  pass2 -> reciprocal;
  reciprocal -> pass2_read;
  pass2_read -> pass2_math;
  pass2_math -> writeback;
  writeback -> pass2_read [xlabel="more input"];
  writeback -> resp [xlabel="done"];
}
