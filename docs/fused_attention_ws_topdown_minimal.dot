// Minimal top-down test for a more intuitive view of FusedAttentionWS.
// This is intentionally a phase tree, not a full cycle-accurate FSM.
//
// Render with:
//   dot -Tsvg docs/fused_attention_ws_topdown_minimal.dot -o docs/fused_attention_ws_topdown_minimal.svg

digraph FusedAttentionWSTopDownMinimal {
  graph [
    rankdir=TB
    splines=ortho
    nodesep=0.45
    ranksep=0.7
    pad=0.25
    labelloc=t
    labeljust=l
    fontname="Helvetica"
    fontsize=18
    bgcolor="white"
    label="FusedAttentionWS top-down test\nMinimal phase tree for readability"
  ];

  node [
    shape=box
    style="rounded,filled"
    fontname="Helvetica"
    fontsize=11
    color="#CBD5E1"
    fillcolor="#F8FAFC"
    margin="0.16,0.10"
  ];

  edge [
    fontname="Helvetica"
    fontsize=10
    color="#64748B"
    arrowsize=0.8
  ];

  root [
    shape=oval
    fillcolor="#E2E8F0"
    label="FusedAttentionWS"
  ];

  commands [
    fillcolor="#FEF3C7"
    label="Command Interface"
  ];

  config_cmds [
    fillcolor="#FEF3C7"
    label="Setup Commands\nfunct 0..3\nset_qk_addrs / set_vout_addrs /\nset_dims / set_params"
  ];

  service_cmds [
    fillcolor="#FEF3C7"
    label="Service Commands\nfunct 5..7\nstatus / read_counter / clear_counters"
  ];

  run_cmd [
    fillcolor="#DBEAFE"
    label="Run Command\nfunct 4"
  ];

  validate [
    shape=diamond
    fillcolor="#DBEAFE"
    label="Config +\ndimensions valid?"
  ];

  fill_q [
    fillcolor="#DBEAFE"
    label="Fill Q Buffer\ns_req_fill_q -> s_wait_fill_q\nreads packed Q into aTileBuf"
  ];

  qk_phase [
    fillcolor="#DBEAFE"
    label="QK Phase"
  ];

  qk_tile_loop [
    fillcolor="#DBEAFE"
    label="QK Tile Loop\nrepeat over KV tiles"
  ];

  qk_setup_tile [
    fillcolor="#DBEAFE"
    label="Setup K Tile\ns_qk_setup_tile\nchoose activeTileCols,\nset K tile base"
  ];

  k_fill [
    fillcolor="#DBEAFE"
    label="Fill K Tile\ns_req_fill_b -> s_wait_fill_b\nreads K tile into bTileBuf"
  ];

  qk_chunk_loop [
    fillcolor="#DBEAFE"
    label="QK Chunk Loop\ns_qk_prep_chunk -> s_qk_load_weights\n-> s_qk_feed_rows -> s_qk_wait_chunk_out\nrepeat over dK in chunks of nRows"
  ];

  score_store [
    fillcolor="#DBEAFE"
    label="Scale + Causal Mask + Store Scores\ns_qk_store_scores\nwrites BF16 scores into scoreBuf"
  ];

  softmax_phase [
    fillcolor="#CFFAFE"
    label="Softmax Phase"
  ];

  softmax_row_loop [
    fillcolor="#CFFAFE"
    label="Softmax Row Loop\nrepeat over qRows"
  ];

  softmax_row_init [
    fillcolor="#CFFAFE"
    label="Row Init\ns_softmax_row_init"
  ];

  softmax_pass1 [
    fillcolor="#CFFAFE"
    label="Pass 1\ns_softmax_p1_load -> s_softmax_p1_compute\nscan row, compute running max + sum"
  ];

  softmax_recip [
    fillcolor="#CFFAFE"
    label="Reciprocal Estimate\nsoftInvSum from LUT-based reciprocal"
  ];

  softmax_pass2 [
    fillcolor="#CFFAFE"
    label="Pass 2\ns_softmax_p2_load -> s_softmax_p2_compute\nnormalize and write probs into aTileBuf"
  ];

  pv_phase [
    fillcolor="#DCFCE7"
    label="PV Phase"
  ];

  pv_setup [
    fillcolor="#DCFCE7"
    label="Setup + Fill V\ns_pv_setup\nthen s_req_fill_b -> s_wait_fill_b\nreads V into bTileBuf"
  ];

  pv_chunk_loop [
    fillcolor="#DCFCE7"
    label="PV Chunk Loop\ns_pv_prep_chunk -> s_pv_load_weights\n-> s_pv_feed_rows -> s_pv_wait_chunk_out\nrepeat over kvRows in chunks of nRows"
  ];

  writeback [
    fillcolor="#E2E8F0"
    label="Quantize + Writeback"
  ];

  quantize [
    fillcolor="#E2E8F0"
    label="Pack Outputs\ns_quantize_out\npack accumTile into BF16 words"
  ];

  put_loop [
    fillcolor="#E2E8F0"
    label="TL Put Loop\ns_req_put -> s_wait_put\nwrite packed words to outBase"
  ];

  resp [
    fillcolor="#E2E8F0"
    label="Respond\ns_resp -> s_idle"
  ];

  note [
    shape=note
    fillcolor="#FFF7ED"
    color="#FDBA74"
    label="Test intent:\nCan a phase tree be clearer than the full left-to-right FSM?\nIf yes, the next step is to rebuild the detailed graph in this style."
  ];

  root -> commands;
  root -> run_cmd;

  commands -> config_cmds;
  commands -> service_cmds;

  run_cmd -> validate;
  validate -> fill_q [xlabel="valid"];
  validate -> resp [xlabel="invalid"];

  fill_q -> qk_phase;
  qk_phase -> qk_tile_loop;
  qk_tile_loop -> qk_setup_tile;
  qk_tile_loop -> k_fill;
  qk_tile_loop -> qk_chunk_loop;
  qk_tile_loop -> score_store;

  score_store -> softmax_phase;
  softmax_phase -> softmax_row_loop;
  softmax_row_loop -> softmax_row_init;
  softmax_row_loop -> softmax_pass1;
  softmax_row_loop -> softmax_recip;
  softmax_row_loop -> softmax_pass2;

  softmax_pass2 -> pv_phase;
  pv_phase -> pv_setup;
  pv_phase -> pv_chunk_loop;

  pv_chunk_loop -> writeback;
  writeback -> quantize;
  writeback -> put_loop;
  writeback -> resp;

  root -> note [style=dashed, color="#D97706"];
}
