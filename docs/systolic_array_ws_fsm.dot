// Render with:
//   dot -Tsvg docs/systolic_array_ws_fsm.dot -o docs/systolic_array_ws_fsm.svg

digraph SystolicArrayWSControl {
  graph [
    rankdir=LR
    labelloc=t
    labeljust=l
    compound=true
    newrank=true
    pad=0.35
    nodesep=0.5
    ranksep=0.85
    splines=polyline
    fontname="Helvetica"
    fontsize=20
    label="SystolicArrayWS control visualization\nMain FSM, command entry, concurrent output capture, and A-prefetch mini-FSM\nSource: src/main/scala/SystolicArrayWS.scala"
    bgcolor="white"
  ];

  node [shape=plain, fontname="Helvetica", margin=0];
  edge [fontname="Helvetica", fontsize=10, color="#475569", arrowsize=0.8];

  legend [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#CBD5E1">
        <TR><TD BGCOLOR="#E2E8F0"><B>Legend</B></TD></TR>
        <TR><TD ALIGN="LEFT">Solid arrows: main FSM state transitions</TD></TR>
        <TR><TD ALIGN="LEFT">Dashed arrows: concurrent side effects or auxiliary FSM interactions</TD></TR>
        <TR><TD ALIGN="LEFT">Amber nodes: RoCC command decode cases from <B>s_idle</B></TD></TR>
        <TR><TD ALIGN="LEFT">Blue nodes: main FSM states</TD></TR>
        <TR><TD ALIGN="LEFT">Green nodes: A-prefetch mini-FSM</TD></TR>
        <TR><TD ALIGN="LEFT">Orange notes: global behavior that updates registers without changing <B>state</B></TD></TR>
      </TABLE>
    >
  ];

  datapath_note [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#CBD5E1">
        <TR><TD BGCOLOR="#F8FAFC"><B>Always-On Datapath Facts</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Defaults:</B> <B>core.io.loadWeights</B> = 0, <B>core.io.clearWeights</B> = 0, <B>core.io.inValid</B> = 0, <B>tlOut.a.valid</B> = 0, <B>tlOut.d.ready</B> = 0</TD></TR>
        <TR><TD ALIGN="LEFT"><B>weightTile:</B> extracted from <B>bCacheBuf[kBaseIdx + row]</B>; rows with <B>row &gt;= chunkK</B> are zero-padded</TD></TR>
        <TR><TD ALIGN="LEFT"><B>currentInVec(i):</B> uses <B>aChunkLanes(i)(safeFeedRowIdx)</B> when <B>i &lt; chunkK</B>, else 0</TD></TR>
        <TR><TD ALIGN="LEFT"><B>safeFeedRowIdx:</B> clamps out-of-range <B>feedRowIdx</B> back to 0 before indexing the active A buffer</TD></TR>
        <TR><TD ALIGN="LEFT"><B>RoCC ports:</B> <B>io.cmd.ready</B> only in <B>s_idle</B>; <B>io.resp.valid</B> only in <B>s_resp</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Key source lines:</B> 577-620, 791-798</TD></TR>
      </TABLE>
    >
  ];

  capture_note [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#FDBA74">
        <TR><TD BGCOLOR="#FFEDD5"><B>Concurrent Output Capture</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Trigger:</B> <B>when(core.io.outValid)</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Writes:</B> for each column <B>c</B>, <B>accumTile(captureRowIdx)(c) += core.io.outVec(c)</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Counter:</B> <B>captureRowIdx := captureRowIdx + 1</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Perf effect:</B> <B>perfCaptureRows</B> increments whenever this fires</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Why it matters:</B> this is independent of the explicit <B>state := ...</B> logic, so the mesh can retire rows while the FSM stays in a wait state</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Key source lines:</B> 950-955, 1196-1200</TD></TR>
      </TABLE>
    >
  ];

  prefetch_gate [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#86EFAC">
        <TR><TD BGCOLOR="#DCFCE7"><B>Prefetch Launch Condition</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>canStartAPrefetch</B> = <B>state</B> in {<B>s_load_weights</B>, <B>s_feed_rows</B>, <B>s_wait_chunk_out</B>}</TD></TR>
        <TR><TD ALIGN="LEFT">and <B>remainingAfterCurrent != 0</B> and <B>!prefetchedValid</B> and <B>prefetchState == pf_idle</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>prefetchedABufSel := activeABufSel ^ 1</B>, <B>prefetchedBaseIdx := kBaseIdx + chunkK</B>, <B>prefetchedChunkK := min(remainingAfterCurrent, chunkKMax)</B>, <B>prefetchFillIdx := 0</B>, <B>prefetchState := pf_req_fill_a</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Design intent:</B> active A-fill uses <B>s_req_fill_a/s_wait_fill_a</B>; prefetch is only launched during compute/drain states, so both paths can safely share source ID 0</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Key source lines:</B> 957-970</TD></TR>
      </TABLE>
    >
  ];

  command_dispatch [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="7" COLOR="#FCD34D">
        <TR><TD BGCOLOR="#FEF3C7"><B>RoCC Command Dispatch</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Guard:</B> only active when <B>io.cmd.fire</B>, which can only happen in <B>s_idle</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Always writes first:</B> <B>respRd := io.cmd.bits.inst.rd</B></TD></TR>
        <TR><TD ALIGN="LEFT"><B>Decode:</B> <B>funct</B> selects config, run, status, preload, counter read, counter clear, or run_preloaded</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Key source lines:</B> 809-947</TD></TR>
      </TABLE>
    >
  ];

  subgraph cluster_commands {
    label="Command Cases Reached From s_idle";
    color="#FCD34D";
    style="rounded";

    cmd_config [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 0 : CONFIG</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>aBase := rs1</B>, <B>bBase := rs2</B>, <B>configured := 1</B>, <B>respData := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 813-819</TD></TR>
        </TABLE>
      >
    ];

    cmd_run [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 1 : RUN</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Inputs:</B> <B>cBase := rs1</B>, <B>requestedK := rs2</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Reset run-local control:</B> <B>kRemaining</B>, <B>kBaseIdx</B>, <B>chunkK</B>, <B>fillIdx</B>, <B>feedRowIdx</B>, <B>captureRowIdx</B>, <B>outIdx</B>, <B>bCacheFillIdx</B>, <B>bIssueIdx</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Reset overlap state:</B> <B>activeABufSel := 0</B>, <B>prefetchedABufSel := 1</B>, <B>prefetchedValid := 0</B>, <B>prefetchedBaseIdx := 0</B>, <B>prefetchedChunkK := 0</B>, <B>prefetchFillIdx := 0</B>, <B>prefetchState := pf_idle</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Clear / reset:</B> all <B>bFillInflight</B> bits low, full <B>accumTile</B> zeroed</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Reuse decision:</B> <B>canReusePinnedWeights = pinnedWeightsValid &amp;&amp; bCacheValid &amp;&amp; (bCacheK == requestedK) &amp;&amp; (cachedBBase == bBase)</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On reuse miss:</B> <B>bFillForRun := 1</B>; invalidate pinned weights; <B>bCacheValid := (requestedK == 0)</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>respData:</B> 1 if not configured, 2 if <B>requestedK &gt; maxK</B>, else 0</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B> on error, <B>s_prep_chunk</B> on reuse hit or <B>K == 0</B>, otherwise <B>s_req_fill_b_cache</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfRunCmds</B>++, optional <B>perfPreloadReuseHits</B>++</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 819-864</TD></TR>
        </TABLE>
      >
    ];

    cmd_run_preloaded [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 6 : RUN_PRELOADED</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Inputs:</B> <B>aBase := rs1</B>, <B>cBase := rs2</B>, <B>requestedK := bCacheK</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Reset run-local state:</B> same control/prefetch registers as RUN, clear <B>accumTile</B>, clear all <B>bFillInflight</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Assumption:</B> reuse already-pinned weights, so <B>bFillForRun := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>respData:</B> 3 if no pinned weights, 2 if <B>requestedK &gt; maxK</B>, else 0</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B> on error, else <B>s_prep_chunk</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfRunCmds</B>++, optional <B>perfPreloadReuseHits</B>++</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 865-904</TD></TR>
        </TABLE>
      >
    ];

    cmd_status [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 2 : STATUS</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>respData:</B> <B>Cat(0..., state =/= s_idle, state == s_resp)</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Meaning:</B> bit 0 reports "currently in response state"; bit 1 reports "busy or returning"</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 905-908</TD></TR>
        </TABLE>
      >
    ];

    cmd_preload [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 3 : PRELOAD_WEIGHTS</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Inputs:</B> <B>bBase := rs1</B>, <B>requestedK := rs2</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Reset B-fill path:</B> <B>bCacheFillIdx := 0</B>, <B>bIssueIdx := 0</B>, clear all <B>bFillInflight</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Reset prefetch path:</B> <B>prefetchedValid := 0</B>, <B>prefetchFillIdx := 0</B>, <B>prefetchState := pf_idle</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Cache metadata:</B> <B>bCacheK := requestedK</B>, <B>bCacheValid := (requestedK == 0)</B>, <B>pinnedWeightsValid := (requestedK == 0)</B>, <B>cachedBBase := rs1</B>, <B>bFillForRun := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>respData:</B> 2 if <B>requestedK &gt; maxK</B>, else 0</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B> when <B>K == 0</B> or too large, otherwise <B>s_req_fill_b_cache</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfPreloadCmds</B>++</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 909-930</TD></TR>
        </TABLE>
      >
    ];

    cmd_read_counter [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 4 : READ_COUNTER</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>counterSel := rs1</B>; if in range return <B>perfCounters(counterIdx)</B>, else return <B>0xBAD0BAD0BAD0BAD0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 931-939</TD></TR>
        </TABLE>
      >
    ];

    cmd_clear_counters [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>funct = 5 : CLEAR_COUNTERS</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>clearPerfCounters := 1</B>, <B>respData := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 940-943, 1176-1180</TD></TR>
        </TABLE>
      >
    ];

    cmd_unknown [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#FCD34D">
          <TR><TD BGCOLOR="#FEF3C7"><B>otherwise : UNKNOWN</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>respData := 0xDEAD</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 944-947</TD></TR>
        </TABLE>
      >
    ];
  }

  subgraph cluster_main_fsm {
    label="Main FSM (state register)";
    color="#93C5FD";
    style="rounded";

    idle [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_idle</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> quiescent state; accept exactly one RoCC command</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Outputs:</B> <B>io.cmd.ready := 1</B>, <B>io.resp.valid := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>State change:</B> only via command decode on <B>io.cmd.fire</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 795, 809-947</TD></TR>
        </TABLE>
      >
    ];

    req_fill_b_cache [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_req_fill_b_cache</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> issue the first B-cache TL Get for a preload or a run-time miss</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.a.valid := bFillCanIssue</B>, <B>tlOut.a.bits := getBCacheIssueBits</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On a.fire:</B> <B>perfTLBReads</B>++, mark <B>bFillInflight(source)</B>, remember <B>bIssueIdx</B>, then <B>bIssueIdx += bIssueWords</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_wait_fill_b_cache</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 972-987</TD></TR>
        </TABLE>
      >
    ];

    wait_fill_b_cache [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_wait_fill_b_cache</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> keep issuing additional B beats while consuming returning data beats</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.a.valid := bFillCanIssue</B>, <B>tlOut.a.bits := getBCacheIssueBits</B>, <B>tlOut.d.ready := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On a.fire:</B> identical bookkeeping to <B>s_req_fill_b_cache</B>; more requests can overlap prior responses</TD></TR>
          <TR><TD ALIGN="LEFT"><B>On d.fire:</B> write returned lanes into <B>bCacheBuf</B>, clear <B>bFillInflight(source)</B>, advance <B>bCacheFillIdx</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Completion:</B> set <B>bCacheValid := 1</B>; if not <B>bFillForRun</B> also set <B>pinnedWeightsValid := 1</B> and <B>cachedBBase := bBase</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_prep_chunk</B> for run-time fills, <B>s_resp</B> for explicit preload commands</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfWaitFillBCycles</B>++ while active</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 989-1022, 1211-1213</TD></TR>
        </TABLE>
      >
    ];

    prep_chunk [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_prep_chunk</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> choose the next chunk source and decide whether execution is finished</TD></TR>
          <TR><TD ALIGN="LEFT"><B>If done:</B> <B>outIdx := 0</B>, then go to <B>s_quantize_out</B> in BF16-output mode or directly to <B>s_req_put</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>If prefetched chunk matches:</B> <B>activeABufSel := prefetchedABufSel</B>, <B>chunkK := prefetchedChunkK</B>, <B>prefetchedValid := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Otherwise:</B> <B>chunkK := min(kRemaining, chunkKMax)</B>, <B>fillIdx := 0</B>, then fetch A for the active buffer</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfChunksStarted</B>++ on every non-terminal chunk start</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 1024-1047</TD></TR>
        </TABLE>
      >
    ];

    req_fill_a [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_req_fill_a</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> issue a TL Get beat for the active A chunk buffer</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.a.valid := 1</B>, <B>tlOut.a.bits := getABits</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On a.fire:</B> <B>perfTLAReads</B>++, then go wait for the returning beat</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 1049-1056</TD></TR>
        </TABLE>
      >
    ];

    wait_fill_a [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_wait_fill_a</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> consume one A beat into the active ping-pong buffer</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.d.ready := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On d.fire:</B> store each valid returned lane into <B>aChunkBufs(activeABufSel)</B>; compute <B>nextIdx := fillIdx + aWordsThisBeat</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_load_weights</B> when the chunk is full, otherwise loop back to <B>s_req_fill_a</B> for the next beat</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfWaitFillACycles</B>++ while active</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 1058-1077, 1214-1216</TD></TR>
        </TABLE>
      >
    ];

    load_weights [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_load_weights</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> pulse the mesh weight-load input for the current chunk</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>core.io.loadWeights := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>feedRowIdx := 0</B>, <B>captureRowIdx := 0</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_feed_rows</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfLoadWeightCycles</B>++ while active</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 1112-1117, 1217-1219</TD></TR>
        </TABLE>
      >
    ];

    feed_rows [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_feed_rows</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> stream one row index per cycle from the active A chunk into the core</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>core.io.inValid := 1</B>, <B>core.io.inVec := currentInVec</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> <B>feedRowIdx := feedRowIdx + 1</B> every cycle</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> remain here until <B>feedRowIdx == nRows - 1</B>, then transition to <B>s_wait_chunk_out</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfFeedCycles</B>++ whenever <B>core.io.inValid</B> is high</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 1119-1125, 1196-1198</TD></TR>
        </TABLE>
      >
    ];

    wait_chunk_out [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_wait_chunk_out</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> drain mesh outputs for the current chunk and wait for the next chunk to be ready</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Guard for exit:</B> <B>captureRowIdx == nRows</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Exit writes:</B> <B>kRemaining := kRemaining - chunkK</B>, <B>kBaseIdx := kBaseIdx + chunkK</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Exit condition:</B> only leave when output drain is done and either <B>remAfter == 0</B> or <B>prefetchedValid</B> is already high</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Why stall can happen:</B> chunk drain may finish before the parallel A-prefetch path finishes loading the next chunk</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfWaitChunkOutCycles</B>++ while active</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 1127-1136, 1220-1222</TD></TR>
        </TABLE>
      >
    ];

    quantize_out [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_quantize_out</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Compiled only when:</B> <B>useBFloat16Output</B> is true</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> register the combinational BF16-packed output words before TileLink writeback</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Writes:</B> copy every <B>packedStoreWordsWire(w)</B> into <B>packedStoreWordsReg(w)</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_req_put</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 1138-1145</TD></TR>
        </TABLE>
      >
    ];

    req_put [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_req_put</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> issue a TL Put beat that writes output words back to memory</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.a.valid := 1</B>, <B>tlOut.a.bits := putBits</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Data source:</B> BF16-packed words from <B>packedStoreWordsReg</B> or raw <B>flatOut</B> words, depending on output mode</TD></TR>
          <TR><TD ALIGN="LEFT"><B>On a.fire:</B> <B>perfTLCWrites</B>++, then wait for write acknowledgement</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 1147-1154, 1208-1210</TD></TR>
        </TABLE>
      >
    ];

    wait_put [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_wait_put</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> wait for the TileLink write acknowledgement for the current output beat</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.d.ready := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On d.fire:</B> assert write ack/source, compute <B>nextOutIdx := outIdx + writeWordsThisBeat</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Next:</B> <B>s_resp</B> when all output words are done, otherwise <B>outIdx := nextOutIdx</B> and go back to <B>s_req_put</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> <B>perfWaitPutCycles</B>++ while active</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 1156-1170, 1223-1225</TD></TR>
        </TABLE>
      >
    ];

    resp [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#93C5FD">
          <TR><TD BGCOLOR="#DBEAFE"><B>s_resp</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> return the previously prepared response to the RoCC interface</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Outputs:</B> <B>io.resp.valid := 1</B>, <B>io.resp.bits.rd := respRd</B>, <B>io.resp.bits.data := respData</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On resp.fire:</B> <B>state := s_idle</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 796-798, 1172-1174</TD></TR>
        </TABLE>
      >
    ];
  }

  subgraph cluster_prefetch_fsm {
    label="A-Prefetch Mini-FSM (prefetchState register)";
    color="#86EFAC";
    style="rounded";

    pf_idle [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#86EFAC">
          <TR><TD BGCOLOR="#DCFCE7"><B>pf_idle</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Meaning:</B> no background A prefetch is in flight</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Entry point:</B> reached after reset-like command setup or after a prefetched chunk becomes valid</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 572-575, 839, 886, 916, 1104</TD></TR>
        </TABLE>
      >
    ];

    pf_req_fill_a [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#86EFAC">
          <TR><TD BGCOLOR="#DCFCE7"><B>pf_req_fill_a</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> request one TL Get beat for the prefetched A chunk buffer</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Active only while main state is:</B> <B>s_load_weights</B>, <B>s_feed_rows</B>, or <B>s_wait_chunk_out</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.a.valid := 1</B>, <B>tlOut.a.bits := getPrefetchABits</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On a.fire:</B> <B>perfTLAReads</B>++, then <B>prefetchState := pf_wait_fill_a</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 1079-1087</TD></TR>
        </TABLE>
      >
    ];

    pf_wait_fill_a [
      label=<
        <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#86EFAC">
          <TR><TD BGCOLOR="#DCFCE7"><B>pf_wait_fill_a</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Purpose:</B> accept the returning prefetched A beat into <B>aChunkBufs(prefetchedABufSel)</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Active only while main state is:</B> <B>s_load_weights</B>, <B>s_feed_rows</B>, or <B>s_wait_chunk_out</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Signals:</B> <B>tlOut.d.ready := 1</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>On d.fire:</B> write valid lanes into the prefetched buffer, then advance <B>prefetchFillIdx</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Completion:</B> when full, set <B>prefetchedValid := 1</B>, clear <B>prefetchFillIdx</B>, and return to <B>pf_idle</B></TD></TR>
          <TR><TD ALIGN="LEFT"><B>Else:</B> go back to <B>pf_req_fill_a</B> for the next beat</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Perf:</B> shares <B>perfWaitFillACycles</B> with the active A-fill path</TD></TR>
          <TR><TD ALIGN="LEFT"><B>Source:</B> 1089-1110, 1214-1216</TD></TR>
        </TABLE>
      >
    ];
  }

  { rank=same; legend; datapath_note; }

  idle -> command_dispatch [style=dashed, color="#D97706", label="io.cmd.fire"];
  command_dispatch -> cmd_config [style=dashed, color="#D97706", label="funct == 0"];
  command_dispatch -> cmd_run [style=dashed, color="#D97706", label="funct == 1"];
  command_dispatch -> cmd_status [style=dashed, color="#D97706", label="funct == 2"];
  command_dispatch -> cmd_preload [style=dashed, color="#D97706", label="funct == 3"];
  command_dispatch -> cmd_read_counter [style=dashed, color="#D97706", label="funct == 4"];
  command_dispatch -> cmd_clear_counters [style=dashed, color="#D97706", label="funct == 5"];
  command_dispatch -> cmd_run_preloaded [style=dashed, color="#D97706", label="funct == 6"];
  command_dispatch -> cmd_unknown [style=dashed, color="#D97706", label="otherwise"];

  cmd_config -> resp [label="always"];
  cmd_status -> resp [label="always"];
  cmd_read_counter -> resp [label="always"];
  cmd_clear_counters -> resp [label="always"];
  cmd_unknown -> resp [label="always"];
  cmd_run -> resp [label="!configured or requestedK > maxK"];
  cmd_run -> prep_chunk [label="reuse hit or requestedK == 0"];
  cmd_run -> req_fill_b_cache [label="otherwise"];
  cmd_run_preloaded -> resp [label="!pinnedWeightsValid or requestedK > maxK"];
  cmd_run_preloaded -> prep_chunk [label="otherwise"];
  cmd_preload -> resp [label="requestedK > maxK or requestedK == 0"];
  cmd_preload -> req_fill_b_cache [label="otherwise"];

  req_fill_b_cache -> req_fill_b_cache [color="#94A3B8", fontcolor="#64748B", label="wait until bFillCanIssue and tlOut.a.fire"];
  req_fill_b_cache -> wait_fill_b_cache [label="tlOut.a.fire"];

  wait_fill_b_cache -> wait_fill_b_cache [color="#94A3B8", fontcolor="#64748B", label="stay while fill is incomplete\nmay issue more a beats and/or consume d beats"];
  wait_fill_b_cache -> prep_chunk [label="d.fire and nextIdx >= bRequestedK and bFillForRun"];
  wait_fill_b_cache -> resp [label="d.fire and nextIdx >= bRequestedK and !bFillForRun"];

  prep_chunk -> quantize_out [label="kRemaining == 0 and useBFloat16Output"];
  prep_chunk -> req_put [label="kRemaining == 0 and !useBFloat16Output"];
  prep_chunk -> load_weights [label="prefetchedValid and prefetchedBaseIdx == kBaseIdx"];
  prep_chunk -> req_fill_a [label="need active A fill"];

  req_fill_a -> req_fill_a [color="#94A3B8", fontcolor="#64748B", label="wait for tlOut.a.fire"];
  req_fill_a -> wait_fill_a [label="tlOut.a.fire"];

  wait_fill_a -> wait_fill_a [color="#94A3B8", fontcolor="#64748B", label="wait for tlOut.d.fire"];
  wait_fill_a -> req_fill_a [label="d.fire and nextIdx < chunkK"];
  wait_fill_a -> load_weights [label="d.fire and nextIdx >= chunkK"];

  load_weights -> feed_rows [label="next cycle"];

  feed_rows -> feed_rows [label="feedRowIdx != nRows - 1"];
  feed_rows -> wait_chunk_out [label="feedRowIdx == nRows - 1"];

  wait_chunk_out -> wait_chunk_out [color="#94A3B8", fontcolor="#64748B", label="wait for captureRowIdx == nRows\nand, if remAfter != 0, prefetchedValid"];
  wait_chunk_out -> prep_chunk [label="captureRowIdx == nRows and (remAfter == 0 or prefetchedValid)"];

  quantize_out -> req_put [label="register BF16 packed words"];

  req_put -> req_put [color="#94A3B8", fontcolor="#64748B", label="wait for tlOut.a.fire"];
  req_put -> wait_put [label="tlOut.a.fire"];

  wait_put -> wait_put [color="#94A3B8", fontcolor="#64748B", label="wait for tlOut.d.fire"];
  wait_put -> req_put [label="d.fire and nextOutIdx < outputWordCount"];
  wait_put -> resp [label="d.fire and nextOutIdx >= outputWordCount"];

  resp -> idle [label="io.resp.fire"];

  load_weights -> capture_note [style=dashed, color="#EA580C", label="mesh starts a new chunk"];
  feed_rows -> capture_note [style=dashed, color="#EA580C", label="inValid pulses create future outValid pulses"];
  wait_chunk_out -> capture_note [style=dashed, color="#EA580C", label="captured rows retire here"];

  load_weights -> prefetch_gate [style=dashed, color="#16A34A", label="canStartAPrefetch check"];
  feed_rows -> prefetch_gate [style=dashed, color="#16A34A", label="canStartAPrefetch check"];
  wait_chunk_out -> prefetch_gate [style=dashed, color="#16A34A", label="canStartAPrefetch check"];
  prefetch_gate -> pf_req_fill_a [style=dashed, color="#16A34A", label="launch background prefetch"];

  pf_idle -> pf_idle [color="#94A3B8", fontcolor="#64748B", label="idle until launch condition"];
  pf_req_fill_a -> pf_req_fill_a [color="#94A3B8", fontcolor="#64748B", label="wait for shared tlOut.a to fire"];
  pf_req_fill_a -> pf_wait_fill_a [label="tlOut.a.fire"];
  pf_wait_fill_a -> pf_wait_fill_a [color="#94A3B8", fontcolor="#64748B", label="wait for shared tlOut.d to fire"];
  pf_wait_fill_a -> pf_req_fill_a [label="d.fire and nextPrefetchIdx < prefetchedChunkK"];
  pf_wait_fill_a -> pf_idle [label="d.fire and nextPrefetchIdx >= prefetchedChunkK"];
}
