// Tiny top-down view of SoftmaxAccel.
//
// Render with:
//   dot -Tsvg docs/softmax_accel_topdown_tiny.dot -o docs/softmax_accel_topdown_tiny.svg

digraph SoftmaxAccelTopDownTiny {
  graph [
    rankdir=TB
    splines=ortho
    nodesep=0.4
    ranksep=0.6
    pad=0.25
    labelloc=t
    labeljust=l
    fontname="Helvetica"
    fontsize=18
    bgcolor="white"
    label="SoftmaxAccel tiny flow"
  ];

  node [
    shape=box
    style="rounded,filled"
    fontname="Helvetica"
    fontsize=11
    color="#CBD5E1"
    fillcolor="#F8FAFC"
    margin="0.16,0.10"
  ];

  edge [
    fontname="Helvetica"
    fontsize=10
    color="#64748B"
    arrowsize=0.8
  ];

  root [
    shape=oval
    fillcolor="#E2E8F0"
    label="SoftmaxAccel\nOnlineSoftmax"
  ];

  pass1 [
    fillcolor="#DBEAFE"
    label="Pass 1\nfunct 0\nread input\nfind global max\naccumulate exp sum"
  ];

  saved_state [
    fillcolor="#FEF3C7"
    label="Saved State\ninBase, length\nmaxPrev, accum"
  ];

  pass2 [
    fillcolor="#CFFAFE"
    label="Pass 2\nfunct 1\nreread input\nnormalize with 1/sum\nwrite BF16 output"
  ];

  done [
    shape=oval
    fillcolor="#E2E8F0"
    label="s_resp\nreturn to CPU"
  ];

  root -> pass1;
  pass1 -> saved_state;
  saved_state -> pass2;
  pass2 -> done;
}
