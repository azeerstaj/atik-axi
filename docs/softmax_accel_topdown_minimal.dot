// Minimal top-down view of SoftmaxAccel.
// SoftmaxAccel instantiates OnlineSoftmax with BF16 output enabled.
// This is intentionally a phase tree, not a full cycle-accurate FSM.
//
// Render with:
//   dot -Tsvg docs/softmax_accel_topdown_minimal.dot -o docs/softmax_accel_topdown_minimal.svg

digraph SoftmaxAccelTopDownMinimal {
  graph [
    rankdir=TB
    splines=ortho
    nodesep=0.45
    ranksep=0.7
    pad=0.25
    labelloc=t
    labeljust=l
    fontname="Helvetica"
    fontsize=18
    bgcolor="white"
    label="SoftmaxAccel top-down\nOnlineSoftmax two-pass BF16 softmax"
  ];

  node [
    shape=box
    style="rounded,filled"
    fontname="Helvetica"
    fontsize=11
    color="#CBD5E1"
    fillcolor="#F8FAFC"
    margin="0.16,0.10"
  ];

  edge [
    fontname="Helvetica"
    fontsize=10
    color="#64748B"
    arrowsize=0.8
  ];

  root [
    shape=oval
    fillcolor="#E2E8F0"
    label="SoftmaxAccel\nOnlineSoftmax"
  ];

  config [
    fillcolor="#FEF3C7"
    label="Config\nintPrecision=32\nfracPrecision=32\nuseBFloat16Output=true\nopcode custom0"
  ];

  commands [
    fillcolor="#FEF3C7"
    label="Command Interface"
  ];

  pass1_cmd [
    fillcolor="#DBEAFE"
    label="Pass 1 Command\nfunct 0: accumulate denominator\nrs1 = input base\nrs2 = array length"
  ];

  pass2_cmd [
    fillcolor="#CFFAFE"
    label="Pass 2 Command\nfunct != 0: normalize + write\nrs1 = output base\nuses saved input base, max, and sum"
  ];

  pass1_init [
    fillcolor="#DBEAFE"
    label="Pass 1 Init\nreset accum, maxPrev,\nprocElements, inAddr\nset doWrite=false"
  ];

  read_loop [
    fillcolor="#DBEAFE"
    label="Input Read Loop\ns_acq -> s_gnt\nTileLink Get one cache beat\nlatch BF16 input vector"
  ];

  findmax [
    fillcolor="#DBEAFE"
    label="Find Beat Max\ns_findmax\nBFloat16VectorMax + BFloat16Max\nupdate maxCurr"
  ];

  reduce [
    fillcolor="#DBEAFE"
    label="Online Denominator Update\ns_exp -> s_reduce\nexp(x - newMax)\naccum := vecSum + accum * exp(oldMax - newMax)"
  ];

  pass1_done [
    fillcolor="#DBEAFE"
    label="Pass 1 Done\ns_resp\nmaxPrev = global max\naccum = denominator sum"
  ];

  recip [
    fillcolor="#CFFAFE"
    label="Reciprocal Estimate\ninvSum := LUT reciprocal(accum)\nnormalize mantissa to [1,2)\nrescale by exponent"
  ];

  pass2_init [
    fillcolor="#CFFAFE"
    label="Pass 2 Init\nset doWrite=true\noutAddr := rs1\ninAddr := saved inBase\nprocElements := 0"
  ];

  normalize [
    fillcolor="#CFFAFE"
    label="Normalize Beat\ns_exp\nexp(x - maxPrev) * invSum\nconvert fixed-point probability to BF16"
  ];

  put_loop [
    fillcolor="#CFFAFE"
    label="Output Put Loop\ns_put -> s_put_ack\nTileLink Put BF16 output beat\nmask invalid tail lanes"
  ];

  resp [
    fillcolor="#E2E8F0"
    label="Respond\ns_resp -> s_idle"
  ];

  note [
    shape=note
    fillcolor="#FFF7ED"
    color="#FDBA74"
    label="Software calls two commands:\n1. online_softmax_accumulate_denominator(input, length)\n2. online_softmax_write_bf16(output)\nThe accelerator rereads the input during pass 2."
  ];

  root -> config;
  root -> commands;
  root -> note [style=dashed, color="#D97706"];

  commands -> pass1_cmd;
  commands -> pass2_cmd;

  pass1_cmd -> pass1_init;
  pass1_init -> read_loop;
  read_loop -> findmax;
  findmax -> reduce;
  reduce -> read_loop [xlabel="more elements"];
  reduce -> pass1_done [xlabel="done"];
  pass1_done -> resp;

  pass2_cmd -> recip;
  recip -> pass2_init;
  pass2_init -> read_loop;
  read_loop -> normalize [xlabel="doWrite"];
  normalize -> put_loop;
  put_loop -> read_loop [xlabel="more elements"];
  put_loop -> resp [xlabel="done"];
}
